<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>FarmaFácil</title>

<style>
body{font-family:Arial;background:#f2f2f2;margin:0}
.container{padding:20px}
input,button,select{padding:10px;margin:5px 0;width:100%}
.btn{background:#0a6847;color:#fff;border:none}
.card{background:#fff;padding:10px;margin:10px 0;border-radius:8px}
</style>
</head>

<body>

<div class="container">

<h2>FarmaFácil</h2>

<h3>Adicionar Produto</h3>
<input id="nome" placeholder="Nome do produto">
<input id="preco" placeholder="Preço">
<button class="btn" onclick="addProduto()">Salvar</button>

<h3>Produtos</h3>
<div id="lista"></div>

<h3>Orçamento</h3>
<select id="selectProd"></select>
<input id="qtd" type="number" value="1">
<button class="btn" onclick="addItem()">Adicionar</button>

<div id="orcamento"></div>

<h3>Total: <span id="total">0</span></h3>

<button class="btn" onclick="enviar()">Enviar WhatsApp</button>

</div>

<script>

let produtos = JSON.parse(localStorage.getItem('produtos')||'[]')
let itens = []

function salvar(){
 localStorage.setItem('produtos',JSON.stringify(produtos))
}

function addProduto(){
 let nome=document.getElementById('nome').value
 let preco=parseFloat(document.getElementById('preco').value)

 if(!nome||!preco)return alert("Preenche certo")

 produtos.push({id:Date.now(),nome,preco})
 salvar()
 render()
}

function render(){
 let lista=document.getElementById('lista')
 let select=document.getElementById('selectProd')

 lista.innerHTML=""
 select.innerHTML=""

 produtos.forEach(p=>{
   lista.innerHTML+=`<div class="card">${p.nome} - R$ ${p.preco}</div>`
   select.innerHTML+=`<option value="${p.id}">${p.nome}</option>`
 })
}

function addItem(){
 let id=document.getElementById('selectProd').value
 let qtd=parseInt(document.getElementById('qtd').value)

 let p=produtos.find(x=>x.id==id)

 itens.push({...p,qtd})

 renderOrc()
}

function renderOrc(){
 let div=document.getElementById('orcamento')
 let total=0
 div.innerHTML=""

 itens.forEach(i=>{
   let sub=i.preco*i.qtd
   total+=sub
   div.innerHTML+=`<div class="card">${i.nome} x${i.qtd} = R$ ${sub}</div>`
 })

 document.getElementById('total').innerText=total
}

function enviar(){
 let msg="Orçamento:\n"

 itens.forEach(i=>{
   msg+=`${i.nome} x${i.qtd}\n`
 })

 let url="https://wa.me/?text="+encodeURIComponent(msg)
 window.open(url)
}

render()

</script>

</body>
</html>
